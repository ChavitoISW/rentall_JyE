# Variables de entorno para GitHub Actions con Podman

# === Container Registry ===
# Automáticas por GitHub, no necesitas configurarlas
# GITHUB_TOKEN (automático)
# GITHUB_ACTOR (automático)

# === SSH Deploy (Requeridas para deploy.yml) ===
# Configurar en: GitHub → Settings → Secrets and variables → Actions

# SSH_PRIVATE_KEY=contenido_completo_de_la_llave_privada_ssh
# SSH_USER=ubuntu
# SSH_HOST=192.168.1.100
# DEPLOY_PATH=/opt/rentall

# === Requisitos del Servidor ===
# El servidor debe tener instalado:
# - Podman (sudo apt-get install podman)
# - podman-compose (pip3 install podman-compose)

# === Opcionales ===
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# EMAIL_TO=admin@tudominio.com
